# Database (Supabase)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# AI (OPENAI_KEY preferred, OPENAI_API_KEY also supported)
OPENAI_KEY=sk-...

# Voice (ELEVENLABS_KEY preferred, ELEVENLABS_API_KEY also supported)
ELEVENLABS_KEY=sk_...
ELEVENLABS_VOICE_ID=  # optional - leave blank to use default voice

# Session security (APP_SESSION_SECRET preferred, SESSION_SECRET also supported)
APP_SESSION_SECRET=change-this-to-a-long-random-string

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...  # Set after registering webhook endpoint
APP_URL=https://echome-production-a33e.up.railway.app

# Environment (ENVIRONMENT preferred, NODE_ENV also supported)
ENVIRONMENT=production
